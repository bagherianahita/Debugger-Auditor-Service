{
    "name": "trust-debugger-service",
    "version": "0.1.0",
    "private": true,
    "main": "dist/index.js",
    "engines": {
      "node": ">=22"
    },
    "scripts": {
      "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
      "clean": "rimraf dist",
      "typecheck": "tsc -p tsconfig.json --noEmit",
      "build": "tsc",
      "start": "node dist/index.js",
      "lint": "eslint .",
      "format": "prettier -w ."
    },
    "dependencies": {
      "express": "^4.19.2",
      "cors": "^2.8.5",
      "helmet": "^7.1.0",
      "morgan": "^1.10.0",
      "zod": "^3.23.8"
    },
    "devDependencies": {
      "@types/cors": "^2.8.17",
      "@types/express": "^4.17.21",
      "@types/morgan": "^1.9.9",
      "@types/node": "^22.10.2",
      "@typescript-eslint/eslint-plugin": "^8.18.0",
      "@typescript-eslint/parser": "^8.18.0",
      "eslint": "^9.17.0",
      "eslint-config-prettier": "^9.1.0",
      "prettier": "^3.4.2",
      "rimraf": "^6.0.1",
      "ts-node-dev": "^2.0.0",
      "typescript": "^5.6.3"
    }
  }